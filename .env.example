# ─── Application ────────────────────────────────────────────────────────────
APP_NAME="Developer Landing Backend"
ENVIRONMENT=development          # development | production
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR

# Comma-separated list of allowed CORS origins. Use * to allow any origin.
CORS_ORIGINS=*

# ─── Storage backend ────────────────────────────────────────────────────────
# file  → JSON/JSONL files on disk   (default; great for local dev)
# redis → Upstash Redis over HTTP    (use this on Vercel / serverless)
STORAGE_BACKEND=file
DATA_DIR=data
LOG_DIR=logs

# ─── Rate limiting (anti-spam) ──────────────────────────────────────────────
RATE_LIMIT_MAX_REQUESTS=5        # max requests per IP per window
RATE_LIMIT_WINDOW_SECONDS=60     # window size in seconds

# ─── AI (Anthropic) ─────────────────────────────────────────────────────────
# Without a key the service still works — AI analysis degrades to a safe
# fallback (graceful degradation).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
AI_TIMEOUT_SECONDS=12

# ─── Email (Resend) ─────────────────────────────────────────────────────────
# Without a key emails are written to the log instead of being delivered.
RESEND_API_KEY=
OWNER_EMAIL=owner@example.com
FROM_EMAIL=onboarding@resend.dev

# ─── Upstash Redis (only when STORAGE_BACKEND=redis) ────────────────────────
# Vercel's Upstash integration injects KV_REST_API_URL / UPSTASH_REDIS_REST_URL
# automatically; any of the aliases below are picked up.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
